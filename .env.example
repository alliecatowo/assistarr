# ==========================================
# Assistarr — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -base64 32

# ==========================================
# AUTHENTICATION (required)
# ==========================================

# Secret key for NextAuth session encryption
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Public URL of your Assistarr instance (no trailing slash)
# Used by NextAuth for callbacks
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# DATABASE (required)
# ==========================================

# PostgreSQL password (used by docker-compose.yml)
# The DATABASE_URL is automatically constructed from these vars in Docker
POSTGRES_PASSWORD=change-me-use-strong-password
POSTGRES_USER=assistarr
POSTGRES_DB=assistarr

# Direct DATABASE_URL (override if using external postgres)
# DATABASE_URL=postgres://assistarr:password@localhost:5432/assistarr

# ==========================================
# AI PROVIDER (at least one required)
# ==========================================

# OpenRouter — recommended, supports 200+ models
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OR: Direct provider keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# ==========================================
# OPTIONAL
# ==========================================

# Encryption key for service credentials stored in DB
# Generate: openssl rand -base64 32
# WARNING: Changing this makes existing encrypted service configs unreadable
ENCRYPTION_KEY=

# Redis URL (only needed with --profile redis)
# Auto-set to redis://redis:6379 when Redis container is running
# REDIS_URL=redis://redis:6379

# ==========================================
# DOCKER / REVERSE PROXY (optional)
# ==========================================

# Port to expose Assistarr on the host (default: 3000)
ASSISTARR_PORT=3000

# Pre-built image to use instead of building locally
# ASSISTARR_IMAGE=ghcr.io/alliecatowo/assistarr:latest

# Traefik integration (set to "true" to enable labels)
TRAEFIK_ENABLED=false
ASSISTARR_DOMAIN=assistarr.local

# ==========================================
# MEDIA STACK NETWORK (optional)
# ==========================================
# If your Radarr/Sonarr/Jellyfin run in Docker, set their network name
# so Assistarr can reach them by container hostname
# MEDIA_NETWORK=media-stack
